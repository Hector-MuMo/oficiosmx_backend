# Copia este archivo como .env y ajusta los valores
# IMPORTANTE: no pongas espacios alrededor del signo =
# CORRECTO:   NODE_ENV=development
# INCORRECTO: NODE_ENV = development

PORT=3000
NODE_ENV=development

# En desarrollo cualquier valor evita el error de "missing key"
# El OTP se imprime en consola y nunca se llama a Resend
RESEND_API_KEY=re_placeholder

FROM_EMAIL=noreply@ejemplo.com
FROM_NAME=OficioMX

# URL del frontend (Vite corre en 5173 por defecto)
FRONTEND_URL=http://localhost:5173

# Token para los endpoints de admin (cualquier cadena sirve para pruebas)
ADMIN_TOKEN=admin123
